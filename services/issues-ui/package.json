{
  "name": "@claude-cadence/issues-ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node -e \"import{writeFileSync}from'fs';writeFileSync('dist/version.json',JSON.stringify({sha:process.env.BUILD_SHA||'dev'}))\"",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "generate": "buf generate"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@xterm/addon-attach": "^0.12.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "graphql": "^16.10.0",
    "graphql-request": "^7.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.66.1",
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@playwright/test": "^1.50.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^29.0.0",
    "jsonwebtoken": "^9.0.2",
    "typescript": "~5.7.0",
    "vite": "^6.1.0",
    "vitest": "^4.1.0"
  }
}
