# Caddy reverse proxy for Claude Cadence services
#
# Usage:
#   Development (localhost, no TLS):
#     caddy run --config infrastructure/Caddyfile
#
#   Production (with automatic HTTPS):
#     CADENCE_DOMAIN=cadence.example.com caddy run --config infrastructure/Caddyfile
#
# Environment variables:
#   CADENCE_DOMAIN  — Set to a domain name for production with automatic HTTPS.
#                     Defaults to :80 (localhost HTTP) when unset.

{$CADENCE_DOMAIN::80} {
	# Issues service — GraphQL API
	handle /graphql {
		reverse_proxy localhost:4000
	}

	# Agents service — gRPC
	handle /agents/* {
		uri strip_prefix /agents
		reverse_proxy localhost:4141 {
			transport http {
				versions h2c
			}
		}
	}

	handle / {
		respond "Claude Cadence API Gateway" 200
	}
}
