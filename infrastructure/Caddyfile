# Caddy reverse proxy for Claude Cadence services
#
# Usage:
#   LAN (internal TLS via Caddy's built-in CA):
#     CADENCE_DOMAIN=cadence.bootsy.internal caddy run --config infrastructure/Caddyfile
#
# Environment variables:
#   CADENCE_DOMAIN  — Hostname to serve on (required).

{$CADENCE_DOMAIN} {
	tls internal

	# Issues service — GraphQL API
	handle /graphql {
		reverse_proxy localhost:4000
	}

	# Agents service — gRPC
	@grpc path_regexp ^/agents\.v1\.
	handle @grpc {
		reverse_proxy localhost:4141 {
			transport http {
				versions h2c
			}
		}
	}

	# Agent Hub — REST API
	handle /api/v1/* {
		reverse_proxy localhost:4200
	}

	# Agent Hub — agent WebSocket registration
	handle /ws/agent {
		reverse_proxy localhost:4200
	}

	# Agent Hub — terminal WebSocket proxy
	handle /ws/terminal/* {
		reverse_proxy localhost:4200
	}

	# Fallback for unmatched routes
	handle {
		respond "Claude Cadence API Gateway" 200
	}
}

# HTTP → HTTPS redirect
http://{$CADENCE_DOMAIN} {
	redir https://{host}{uri} permanent
}
