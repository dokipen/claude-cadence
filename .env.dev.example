# Copy this file to .env.dev and fill in your values.
# .env.dev is gitignored and must never be committed.

# ---------------------------------------------------------------------------
# Issues Service
# ---------------------------------------------------------------------------

# Note: docker-compose.dev.yml sets AUTH_BYPASS=1 by default, which disables
# GitHub OAuth authentication entirely. The GitHub OAuth vars below are NOT
# required when using AUTH_BYPASS=1.

# Secret used to sign JWTs for authenticated API requests.
# Generate with: openssl rand -hex 32
# Optional: only needed if AUTH_BYPASS is not set
JWT_SECRET=change-me-to-a-random-secret

# GitHub OAuth app credentials for login.
# Create an OAuth app at https://github.com/settings/developers
# Set the callback URL to: http://localhost/auth/github/callback
# Optional: only needed if AUTH_BYPASS is not set
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# Comma-separated list of GitHub usernames allowed to log in.
# Leave empty to allow any authenticated GitHub user.
# Optional: only needed if AUTH_BYPASS is not set
ALLOWED_USERS=

# ---------------------------------------------------------------------------
# Agent Hub (only needed when running with --profile agents)
# ---------------------------------------------------------------------------

# Bearer token for REST API clients (e.g. the issues UI) to authenticate with agent-hub.
HUB_API_TOKEN=change-me

# Bearer token that agentd instances use to register with agent-hub.
HUB_AGENT_TOKEN=change-me

# ---------------------------------------------------------------------------
# agentd (only needed when running with --profile agents)
# ---------------------------------------------------------------------------

# Shared bearer token agentd uses for its own gRPC API (when auth.mode = "token").
AGENTD_TOKEN=change-me

# ---------------------------------------------------------------------------
# issues-ui (Vite dev server proxy)
# ---------------------------------------------------------------------------

# Hostname the Vite proxy uses to reach the issues GraphQL API.
# When running via docker-compose, set this to the Docker service name so
# containers can reach each other. Leave unset (defaults to "localhost") for
# local dev outside Docker.
VITE_API_HOST=issues
